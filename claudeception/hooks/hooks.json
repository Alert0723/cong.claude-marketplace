{
  "description": "Claudeception auto-activation hook - injects mandatory skill evaluation reminder on every user prompt",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/claudeception-activator.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
